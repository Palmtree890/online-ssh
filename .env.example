# ─── Required ────────────────────────────────────────────────────────────────

# Admin login credentials
ADMIN_USERNAME=admin

# Generate with: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

# Random secret for JWT signing — generate with: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string

# Random secret for AES-256 encryption — generate with: openssl rand -base64 48
ENCRYPTION_SECRET=change_me_to_another_long_random_string

# ─── Optional ─────────────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Path to SQLite database file (default: ./data/ssh-client.db)
# DB_PATH=./data/ssh-client.db

# Directory to store session log files (default: ./logs)
# LOG_DIR=./logs

# SSL/TLS — provide both to enable HTTPS, otherwise falls back to HTTP
# SSL_CERT_PATH=/etc/ssl/certs/server.crt
# SSL_KEY_PATH=/etc/ssl/private/server.key

# Set to "production" to enable secure cookies (requires HTTPS)
# NODE_ENV=production
